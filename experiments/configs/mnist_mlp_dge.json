{
    "name": "mnist_mlp_dge",
    "dataset": "mnist",
    "n_train": 3000,
    "n_test": 600,
    "batch_size": 256,
    "budget": 100000,
    "architecture": [784, 32, 10],
    "optimizer": {
        "name": "dge",
        "lr": 0.5,
        "lr_decay": 0.01,
        "delta": 0.001,
        "greedy_w": 0.1,
        "clip_norm": 0.05,
        "dense_update": false
    }
}