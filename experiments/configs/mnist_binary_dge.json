{
    "name": "mnist_binary_dge",
    "dataset": "mnist",
    "weight_quantization": "binary",
    "use_bias": false,
    "n_train": 3000,
    "n_test": 600,
    "batch_size": 256,
    "budget": 150000,
    "architecture": [784, 128, 10],
    "optimizer": {
        "name": "dge",
        "lr": 0.5,
        "lr_decay": 0.01,
        "delta": 0.01,
        "greedy_w": 0.3,
        "clip_norm": 0.1,
        "dense_update": false
    }
}